export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="avit"

zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 13

# Move zcompdump out of $HOME (cleaner, sandbox-friendly)
export ZSH_COMPDUMP="$HOME/.cache/oh-my-zsh/zcompdump-${SHORT_HOST}-${ZSH_VERSION}"

# Skip compfix check (avoids nice(5) error in sandbox)
ZSH_DISABLE_COMPFIX=true

plugins=(git)

source $ZSH/oh-my-zsh.sh

# GPG
export GPG_TTY=$(tty)

# Aliases
alias v="nvim"
alias vim="nvim"
alias vi="nvim"
alias lg='lazygit'
alias ta="tmux attach"
alias p="pnpm"
alias px='pnpm exec'
alias pdx='pnpm dlx'
alias pn='pnpm exec nx'
alias pnr='pnpm exec nx run'
alias dc="docker-compose"

cc() {
  CLAUDE_CODE_SSE_PORT=$(cat ~/.claude/ide/*.lock(N) < /dev/null 2>/dev/null | jq -r ".port") claude "$@"
}

# Bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# ImageMagick
export MAGICK_HOME=$(brew --prefix imagemagick 2>/dev/null)
