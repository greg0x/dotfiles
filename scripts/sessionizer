#!/usr/bin/env bash

source "$HOME/dotfiles/scripts/session-state"

CONFIG="$HOME/dotfiles/tmux/session-colors"
HISTORY="$HOME/.cache/sessionizer-history"
SANDBOX=true
SANDBOX_EXPLICIT=false

# Parse flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-sandbox) SANDBOX=false; SANDBOX_EXPLICIT=true; shift ;;
        *) break ;;
    esac
done

# Get paths for currently open tmux sessions
get_session_paths() {
    tmux list-sessions -F '#{session_name}' 2>/dev/null | while read -r session; do
        # Get the working directory of the first pane in the first window
        tmux display-message -t "$session:1.1" -p '#{pane_current_path}' 2>/dev/null
    done
}

# Accept a directory path as argument to skip fzf (used by worktree script)
if [[ -n "${1:-}" && -d "$1" ]]; then
    selected="$1"
    key=""
else
    # Build list: open sessions first, then recent, then all directories
    # alt-enter opts out of sandbox for trusted repos
    selected=$({
        get_session_paths
        [[ -f "$HISTORY" ]] && cat "$HISTORY"
        echo "$HOME/notes"
        echo "$HOME/dotfiles"
        fd -H --type d --max-depth 4 . ~/dev
        # Include gitignored child repos in workspace directories
        fd --no-ignore --type d --max-depth 1 . ~/dev/zcash/shielded-vote-workspace
    } | awk '!seen[$0]++' | fzf --reverse --scheme=history \
        --header "$(if $SANDBOX; then echo '🔒 SANDBOX (alt-enter: unsandboxed)'; else echo 'alt-enter: sandbox'; fi)" \
        --expect=alt-enter)

    # fzf --expect outputs the key pressed on the first line, selection on second
    key=$(head -1 <<< "$selected")
    selected=$(tail -1 <<< "$selected")
fi

[[ -z $selected ]] && exit 0

# alt-enter toggles sandbox off
if [[ "$key" == "alt-enter" ]]; then
    SANDBOX=false
    SANDBOX_EXPLICIT=true
fi

# Update history: add selection to top, keep last 20
{
    echo "$selected"
    [[ -f "$HISTORY" ]] && grep -v "^${selected}$" "$HISTORY" | head -19
} > "$HISTORY.tmp" && mv "$HISTORY.tmp" "$HISTORY"

# Session name from folder name, replace dots/spaces with underscores
base_name=$(basename "$selected" | tr './ ' '___')

# Check if this session already exists (with any prefix)
existing=$(tmux list-sessions -F '#S' 2>/dev/null | grep -E "^[0-9]+_${base_name}$" | head -1)
if [[ -n $existing ]]; then
    session_name="$existing"
else
    # Assign next available numeric prefix
    max_prefix=$(tmux list-sessions -F '#S' 2>/dev/null | grep -oE '^[0-9]+' | sort -n | tail -1)
    next_prefix=$(printf "%02d" $(( ${max_prefix:--1} + 1 )))
    session_name="${next_prefix}_${base_name}"
fi

# Respect the saved sandbox mode for restored sessions unless explicitly
# overridden by a flag or alt-enter.
if ! $SANDBOX_EXPLICIT; then
    saved_sandbox=$(session_state_saved_sandbox "$selected" 2>/dev/null || true)
    if [[ "$saved_sandbox" == "true" ]]; then
        SANDBOX=true
    elif [[ "$saved_sandbox" == "false" ]]; then
        SANDBOX=false
    fi
fi

# Apply saved color for session
apply_session_color() {
    local session="$1"
    local color
    local dark="#1a1b26"

    if [[ -f "$CONFIG" ]]; then
        # Strip numeric prefix for color lookup (e.g., "03_pir" -> "pir")
        local lookup_name
        lookup_name=$(echo "$session" | sed 's/^[0-9]*_//')
        color=$(grep "^${lookup_name}:" "$CONFIG" | cut -d: -f2)
    fi

    if [[ -n $color ]]; then
        tmux set-option -t "$session" @session_color "$color"
        tmux set-option -g status-bg "$color"
        tmux set-option -g status-fg "$dark"
        tmux set-option -g status-left "#[bg=$color,fg=$dark,bold] #{?@sandbox,󰌾 ,}#S "
        tmux set-option -g status-right "#[bg=$color,fg=$dark] %a %d %b %H:%M "
        tmux set-option -g window-status-current-format "#[bg=$color,fg=$dark,bold] #I:#{?window_zoomed_flag,󰊓 ,}#{?automatic-rename,[#{P:#{?pane_active,*,}#{pane_current_command} }],#W} "
        tmux set-option -g window-status-format "#[bg=$color,fg=$dark] #I:#{?automatic-rename,[#{P:#{pane_current_command} }],#W} "
    fi
}

# Function to create the default session layout
create_default_session() {
    local sb
    if $SANDBOX; then
        sb=$(session_state_build_sandbox_wrapper "$selected")
    fi

    # Create session with first window
    if $SANDBOX; then
        tmux new-session -ds "$session_name" -c "$selected" -n "editor" "$sb -- zsh -lic 'nvim; exec zsh'"
        # All new panes/windows in this session inherit the sandbox
        tmux set-option -t "$session_name" default-command "$sb -- zsh -li"
        tmux set-option -t "$session_name" @sandbox 1
    else
        tmux new-session -ds "$session_name" -c "$selected" -n "editor"
        tmux send-keys -t "$session_name:editor.1" 'nvim' Enter
    fi

    # Determine CC resume flags from saved sessions
    local cc_sessions="$selected/.session/claude-sessions"
    local cc_ids=()
    if [[ -f "$cc_sessions" ]]; then
        while IFS= read -r id; do [[ -n "$id" ]] && cc_ids+=("$id"); done < "$cc_sessions"
    fi
    local cc_first="${cc_ids[0]:-}"
    local cc_flag
    if [[ -n "$cc_first" ]]; then
        cc_flag="--resume $cc_first"
    else
        cc_flag="--continue"
    fi

    # Window 1: nvim (left) | claude (right)
    if $SANDBOX; then
        tmux split-window -t "$session_name:editor" -h -l 50% -c "$selected" "$sb -- zsh -lic 'cc $cc_flag; exec zsh'"
    else
        tmux split-window -t "$session_name:editor" -h -l 50% -c "$selected"
        tmux send-keys -t "$session_name:editor.2" "cc $cc_flag" Enter
    fi

    # Restore additional CC instances in new windows
    for id in "${cc_ids[@]:1}"; do
        if $SANDBOX; then
            tmux new-window -t "$session_name" -c "$selected" -n "claude" "$sb -- zsh -lic 'cc --resume $id; exec zsh'"
        else
            tmux new-window -t "$session_name" -c "$selected" -n "claude"
            tmux send-keys -t "$session_name:claude" "cc --resume $id" Enter
        fi
    done

    # Shell window (always last)
    if $SANDBOX; then
        tmux new-window -t "$session_name" -c "$selected" -n "shell" "$sb -- zsh -li"
    else
        tmux new-window -t "$session_name" -n "shell" -c "$selected"
    fi

    # Focus back on nvim
    tmux select-window -t "$session_name:editor"
    tmux select-pane -t "$session_name:editor.1"
}

create_session() {
    local sandbox_value

    if $SANDBOX; then
        sandbox_value=true
    else
        sandbox_value=false
    fi

    if restore_tmux_session_state "$session_name" "$selected" "$sandbox_value"; then
        return 0
    fi

    create_default_session
}

# Not in tmux - create and attach
if [[ -z $TMUX ]]; then
    if ! tmux has-session -t="$session_name" 2>/dev/null; then
        create_session
        apply_session_color "$session_name"
    fi
    tmux attach -t "$session_name"
    exit 0
fi

# In tmux - create if needed, then switch
if ! tmux has-session -t="$session_name" 2>/dev/null; then
    create_session
    apply_session_color "$session_name"
fi

tmux switch-client -t "$session_name"
