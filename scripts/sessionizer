#!/usr/bin/env bash

CONFIG="$HOME/dotfiles/tmux/session-colors"
HISTORY="$HOME/.cache/sessionizer-history"
SANDBOX=true

# Parse flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-sandbox) SANDBOX=false; shift ;;
        *) break ;;
    esac
done

# Get paths for currently open tmux sessions
get_session_paths() {
    tmux list-sessions -F '#{session_name}' 2>/dev/null | while read -r session; do
        # Get the working directory of the first pane in the first window
        tmux display-message -t "$session:1.1" -p '#{pane_current_path}' 2>/dev/null
    done
}

# Build list: open sessions first, then recent, then all directories
# ctrl-s opts out of sandbox for trusted repos
selected=$({
    get_session_paths
    [[ -f "$HISTORY" ]] && cat "$HISTORY"
    echo "$HOME/notes"
    echo "$HOME/dotfiles"
    fd -H --type d --max-depth 4 . ~/dev
    # Include gitignored child repos in workspace directories
    fd --no-ignore --type d --max-depth 1 . ~/dev/zcash/shielded-vote-workspace
} | awk '!seen[$0]++' | fzf --reverse --scheme=history \
    --header "$(if $SANDBOX; then echo '🔒 SANDBOX (ctrl-s: disable)'; else echo 'ctrl-s: enable sandbox'; fi)" \
    --expect=ctrl-s)

# fzf --expect outputs the key pressed on the first line, selection on second
key=$(head -1 <<< "$selected")
selected=$(tail -1 <<< "$selected")

[[ -z $selected ]] && exit 0

# ctrl-s during fzf toggles sandbox off
[[ "$key" == "ctrl-s" ]] && SANDBOX=false

# Update history: add selection to top, keep last 20
{
    echo "$selected"
    [[ -f "$HISTORY" ]] && grep -v "^${selected}$" "$HISTORY" | head -19
} > "$HISTORY.tmp" && mv "$HISTORY.tmp" "$HISTORY"

# Session name from folder name, replace dots/spaces with underscores
base_name=$(basename "$selected" | tr './ ' '___')

# Check if this session already exists (with any prefix)
existing=$(tmux list-sessions -F '#S' 2>/dev/null | grep -E "^[0-9]+_${base_name}$" | head -1)
if [[ -n $existing ]]; then
    session_name="$existing"
else
    # Assign next available numeric prefix
    max_prefix=$(tmux list-sessions -F '#S' 2>/dev/null | grep -oE '^[0-9]+' | sort -n | tail -1)
    next_prefix=$(printf "%02d" $(( ${max_prefix:--1} + 1 )))
    session_name="${next_prefix}_${base_name}"
fi

# Apply saved color for session
apply_session_color() {
    local session="$1"
    local color
    local dark="#1a1b26"

    if [[ -f "$CONFIG" ]]; then
        # Strip numeric prefix for color lookup (e.g., "03_pir" -> "pir")
        local lookup_name
        lookup_name=$(echo "$session" | sed 's/^[0-9]*_//')
        color=$(grep "^${lookup_name}:" "$CONFIG" | cut -d: -f2)
    fi

    if [[ -n $color ]]; then
        tmux set-option -t "$session" @session_color "$color"
        tmux set-option -g status-bg "$color"
        tmux set-option -g status-fg "$dark"
        tmux set-option -g status-left "#[bg=$color,fg=$dark,bold] #S "
        tmux set-option -g status-right "#[bg=$color,fg=$dark] %a %d %b %H:%M "
        tmux set-option -g window-status-current-format "#[bg=$color,fg=$dark,bold] #I:#{?window_zoomed_flag,󰊓 ,}[#{P:#{?pane_active,*,}#{pane_current_command} }] "
        tmux set-option -g window-status-format "#[bg=$color,fg=$dark] #I:[#{P:#{pane_current_command} }] "
    fi
}

# Function to create session with layout
create_session() {
    local sb
    if $SANDBOX; then
        sb="safehouse --workdir='$selected' --env-pass=TMUX --enable=shell-init,keychain --add-dirs-ro='$HOME/dotfiles:$HOME/.local/share/mise:$HOME/.local/share/claude:$HOME/.local/bin:$HOME/.config:$HOME/.oh-my-zsh:$HOME/dev/devenv/octo.nvim' --add-dirs='$HOME/.claude:$HOME/.claude.json:$HOME/.local/share/nvim:$HOME/.local/state/nvim:$HOME/.cache/nvim:$HOME/.cache/oh-my-zsh:/private/tmp/tmux-$(id -u)'"
    fi

    # Create session with first window
    if $SANDBOX; then
        tmux new-session -ds "$session_name" -c "$selected" -n "editor" "$sb -- zsh -lic 'nvim; exec zsh'"
        # All new panes/windows in this session inherit the sandbox
        tmux set-option -t "$session_name" default-command "$sb -- zsh -li"
    else
        tmux new-session -ds "$session_name" -c "$selected" -n "editor"
        tmux send-keys -t "$session_name:editor.1" 'nvim' Enter
    fi

    # Window 1: nvim (left) | claude (right)
    if $SANDBOX; then
        tmux split-window -t "$session_name:editor" -h -l 50% -c "$selected" "$sb -- zsh -lic 'cc; exec zsh'"
    else
        tmux split-window -t "$session_name:editor" -h -l 50% -c "$selected"
        tmux send-keys -t "$session_name:editor.2" "cc" Enter
    fi

    # Window 2: plain shell
    if $SANDBOX; then
        tmux new-window -t "$session_name" -c "$selected" -n "shell" "$sb -- zsh -li"
    else
        tmux new-window -t "$session_name" -n "shell" -c "$selected"
    fi

    # Focus back on nvim
    tmux select-window -t "$session_name:editor"
    tmux select-pane -t "$session_name:editor.1"
}

# Not in tmux - create and attach
if [[ -z $TMUX ]]; then
    if ! tmux has-session -t="$session_name" 2>/dev/null; then
        create_session
        apply_session_color "$session_name"
    fi
    tmux attach -t "$session_name"
    exit 0
fi

# In tmux - create if needed, then switch
if ! tmux has-session -t="$session_name" 2>/dev/null; then
    create_session
    apply_session_color "$session_name"
fi

tmux switch-client -t "$session_name"
