#!/usr/bin/env bash

# Switch to next/prev session by name order (not creation order)
# Usage: session-switch next|prev

direction="$1"
current=$(tmux display-message -p '#S')

# Get all sessions sorted by name
sessions=()
while IFS= read -r s; do sessions+=("$s"); done < <(tmux list-sessions -F '#S' | sort)

count=${#sessions[@]}
(( count <= 1 )) && exit 0

# Find current session's index
for i in "${!sessions[@]}"; do
    if [[ "${sessions[$i]}" == "$current" ]]; then
        if [[ "$direction" == "next" ]]; then
            target_idx=$(( (i + 1) % count ))
        else
            target_idx=$(( (i - 1 + count) % count ))
        fi
        tmux switch-client -t "${sessions[$target_idx]}"
        exit 0
    fi
done
